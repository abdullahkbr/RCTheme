<link rel="stylesheet" href="{{ 'custom_hero.css' | asset_url }}">
<div class="custom_hero">
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'heading' %}
        <h1 class="custom_hero_heading">{{ block.settings.heading_text }}</h1>
      {% when 'text' %}
        <p class="custom_hero_text">{{ block.settings.text_content }}</p>
      {% when 'link' %}
        {% assign link_text = block.settings.link_text | strip %}
        {% assign link_url = block.settings.link_url %}
        {% if link_url != blank and link_text != blank %}
          <a href="{{ block.settings.link_url }}" class="custom_hero_link">
            {{ link_text }}
          </a>
        {% endif %} 
      {% else %} 
    {% endcase %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Custom Hero",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },

  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "heading_text",
          "label": "Heading Text",
          "default": "Your Heading Here"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "textarea",
          "id": "text_content",
          "label": "Text Content",
          "default": "Write your description here"
        }
      ]
    },
    {
      "type": "link",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "link_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Button Link"
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "Custom Hero",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "link" }
      ]
    }
  ]
}
{% endschema %}
